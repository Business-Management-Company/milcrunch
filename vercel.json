{
  "crons": [
    { "path": "/api/refresh-avatars", "schedule": "0 6 * * *" }
  ],
  "functions": {
    "api/upload-photos.js": { "maxDuration": 60 },
    "api/upload-text.js": { "maxDuration": 60 },
    "api/upload-videos.js": { "maxDuration": 60 },
    "api/uploadpost-proxy.js": { "maxDuration": 60 }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)\\.js",
      "headers": { "Cache-Control": "no-cache" },
      "continue": true
    },
    { "src": "/api/upload-photos", "dest": "/api/upload-photos", "methods": ["GET", "POST", "OPTIONS"] },
    { "src": "/api/upload-text", "dest": "/api/upload-text", "methods": ["GET", "POST", "OPTIONS"] },
    { "src": "/api/upload-videos", "dest": "/api/upload-videos", "methods": ["GET", "POST", "OPTIONS"] },
    { "src": "/api/uploadpost-proxy", "dest": "/api/uploadpost-proxy", "methods": ["GET", "POST", "OPTIONS"] },
    { "src": "/api/shorten-url", "dest": "/api/shorten-url", "methods": ["GET", "POST", "OPTIONS"] },
    { "src": "/api/influencers/(.*)", "dest": "/api/influencers" },
    { "src": "/api/enrich/(.*)", "dest": "/api/enrich" },
    { "src": "/api/credits", "dest": "/api/credits" },
    { "src": "/api/search-username", "dest": "/api/search-username" },
    { "src": "/api/search-lookalike", "dest": "/api/search-lookalike" },
    { "src": "/api/serp/(.*)", "dest": "/api/serp" },
    { "src": "/api/firecrawl/(.*)", "dest": "/api/firecrawl" },
    { "src": "/api/pdl/(.*)", "dest": "/api/pdl" },
    { "src": "/api/places", "dest": "/api/places" },
    { "src": "/api/anthropic", "dest": "/api/anthropic" },
    { "src": "/api/save-avatar", "dest": "/api/save-avatar" },
    { "src": "/api/upload-creator-image", "dest": "/api/upload-creator-image" },
    { "src": "/api/upload-image", "dest": "/api/upload-image" },
    { "src": "/api/openai-image", "dest": "/api/openai-image" },
    { "src": "/api/youtube", "dest": "/api/youtube" },
    { "src": "/api/parse-rss", "dest": "/api/parse-rss" },
    { "src": "/api/podcast-rss", "dest": "/api/podcast-rss" },
    { "src": "/api/social-monitor", "dest": "/api/social-monitor" },
    { "src": "/api/social-listening-scan", "dest": "/api/social-listening-scan" },
    { "src": "/api/social-listening-agent", "dest": "/api/social-listening-agent" },
    { "src": "/api/shared-reports", "dest": "/api/shared-reports" },
    { "src": "/api/ensure-post-drafts", "dest": "/api/ensure-post-drafts" },
    { "src": "/api/backfill-avatars", "dest": "/api/backfill-avatars" },
    { "src": "/api/cleanup-avatars", "dest": "/api/cleanup-avatars" },
    { "src": "/api/refresh-avatars", "dest": "/api/refresh-avatars" },
    { "src": "/api/migrate-avatars", "dest": "/api/migrate-avatars" },
    { "src": "/api/re-enrich-avatars", "dest": "/api/re-enrich-avatars" },
    { "src": "/api/enrich-profile", "dest": "/api/enrich-profile" },
    { "src": "/api/fix-avatars", "dest": "/api/fix-avatars" },
    { "src": "/api/ic-locations", "dest": "/api/ic-locations" },
    { "src": "/api/resend-verify-domain", "dest": "/api/resend-verify-domain" },
    { "src": "/api/resend/(.*)", "dest": "https://api.resend.com/$1" },
    { "src": "/api/resolve-handle", "dest": "/api/resolve-handle" },
    { "src": "/api/generate-caption", "dest": "/api/generate-caption" },
    { "src": "/api/(.*)", "dest": "/api/$1", "methods": ["GET", "POST", "OPTIONS", "PUT", "DELETE", "PATCH"] },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
