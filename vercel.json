{
  "crons": [
    { "path": "/api/refresh-avatars", "schedule": "0 6 * * *" }
  ],
  "functions": {
    "api/upload-photos.js": { "maxDuration": 60 },
    "api/upload-text.js": { "maxDuration": 60 },
    "api/upload-videos.js": { "maxDuration": 60 },
    "api/uploadpost-proxy.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ],
  "rewrites": [
    {"source": "/api/influencers/:path(.*)", "destination": "/api/influencers"},
    {"source": "/api/enrich/:path(.*)", "destination": "/api/enrich"},
    {"source": "/api/credits", "destination": "/api/credits"},
    {"source": "/api/search-username", "destination": "/api/search-username"},
    {"source": "/api/search-lookalike", "destination": "/api/search-lookalike"},
    {"source": "/api/serp/:path(.*)", "destination": "/api/serp"},
    {"source": "/api/firecrawl/:path(.*)", "destination": "/api/firecrawl"},
    {"source": "/api/pdl/:path(.*)", "destination": "/api/pdl"},
    {"source": "/api/places", "destination": "/api/places"},
    {"source": "/api/anthropic", "destination": "/api/anthropic"},
    {"source": "/api/save-avatar", "destination": "/api/save-avatar"},
    {"source": "/api/upload-creator-image", "destination": "/api/upload-creator-image"},
    {"source": "/api/upload-image", "destination": "/api/upload-image"},
    {"source": "/api/openai-image", "destination": "/api/openai-image"},
    {"source": "/api/youtube", "destination": "/api/youtube"},
    {"source": "/api/parse-rss", "destination": "/api/parse-rss"},
    {"source": "/api/podcast-rss", "destination": "/api/podcast-rss"},
    {"source": "/api/social-monitor", "destination": "/api/social-monitor"},
    {"source": "/api/social-listening-scan", "destination": "/api/social-listening-scan"},
    {"source": "/api/social-listening-agent", "destination": "/api/social-listening-agent"},
    {"source": "/api/shared-reports", "destination": "/api/shared-reports"},
    {"source": "/api/ensure-post-drafts", "destination": "/api/ensure-post-drafts"},
    {"source": "/api/backfill-avatars", "destination": "/api/backfill-avatars"},
    {"source": "/api/cleanup-avatars", "destination": "/api/cleanup-avatars"},
    {"source": "/api/refresh-avatars", "destination": "/api/refresh-avatars"},
    {"source": "/api/migrate-avatars", "destination": "/api/migrate-avatars"},
    {"source": "/api/re-enrich-avatars", "destination": "/api/re-enrich-avatars"},
    {"source": "/api/enrich-profile", "destination": "/api/enrich-profile"},
    {"source": "/api/fix-avatars", "destination": "/api/fix-avatars"},
    {"source": "/api/ic-locations", "destination": "/api/ic-locations"},
    {"source": "/api/resend-verify-domain", "destination": "/api/resend-verify-domain"},
    {"source": "/api/resend/:path*", "destination": "https://api.resend.com/:path*"},
    {"source": "/api/resolve-handle", "destination": "/api/resolve-handle"},
    {"source": "/api/generate-caption", "destination": "/api/generate-caption"},
    {"source": "/api/upload-photos", "destination": "/api/upload-photos"},
    {"source": "/api/upload-text", "destination": "/api/upload-text"},
    {"source": "/api/upload-videos", "destination": "/api/upload-videos"},
    {"source": "/api/uploadpost-proxy", "destination": "/api/uploadpost-proxy"},
    {"source": "/api/shorten-url", "destination": "/api/shorten-url"},
    {"source": "/api/:path(.*)", "destination": "/api/:path"},
    {"source": "/(.*)", "destination": "/index.html"}
  ]
}
