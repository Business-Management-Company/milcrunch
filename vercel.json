{
  "rewrites": [
    {"source": "/api/influencers/:path(.*)", "destination": "/api/influencers"},
    {"source": "/api/enrich/:path(.*)", "destination": "/api/enrich"},
    {"source": "/api/credits", "destination": "/api/credits"},
    {"source": "/api/serp/:path(.*)", "destination": "/api/serp"},
    {"source": "/api/firecrawl/:path(.*)", "destination": "/api/firecrawl"},
    {"source": "/api/pdl/:path(.*)", "destination": "/api/pdl"},
    {"source": "/api/resend/:path*", "destination": "https://api.resend.com/:path*"},
    {"source": "/api/uploadpost/:path*", "destination": "https://api.upload-post.com/:path*"},
    {"source": "/((?!api/).*)", "destination": "/index.html"}
  ]
}
